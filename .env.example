# ============================================
# CSG FLUX DASHBOARD - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# DEPLOYMENT MODE
# Set to "true" for HuggingFace demo, "false" for production
DEMO_MODE=false

# SECURITY (REQUIRED - Generate secure random strings for production)
# Used for signing JWT tokens - must be at least 32 characters
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars

# INITIAL ADMIN ACCOUNT (created on first run if database is empty)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# DATABASE
DATABASE_URL=sqlite:///./data/crop_dashboard.db

# DATABASE ENCRYPTION (REQUIRED)
# SQLCipher encryption key - protects database at rest
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# WARNING: If this key is lost, the database cannot be recovered!
DB_ENCRYPTION_KEY=

# NOTE: For development without SQLCipher installed, run with:
#   CROPDASH_DEV_ALLOW_UNENCRYPTED=true python -m uvicorn backend.main:app ...
# This flag is intentionally NOT settable via .env to prevent accidents.

# CORS (allowed origins for API requests)
# For production, set to your actual domain(s)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# BOX INTEGRATION (Optional - for cloud file sync)
# Get credentials from https://app.box.com/developers/console
# 1. Create app with "User Authentication (OAuth 2.0)"
# 2. Add redirect URI matching BOX_REDIRECT_URI below
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_REDIRECT_URI=http://localhost:5173/admin/box/callback
